# Copy this file to `.env` and fill in your Supabase project values.
# Project settings → API in the Supabase dashboard.
# These are EXPO_PUBLIC_ vars so they are inlined into the client bundle;
# the anon key is safe to ship (Row-Level Security protects the data).

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Google OAuth client IDs (Google Cloud Console → Credentials).
# Needed for Google sign-in in a dev/production build (not Expo Go).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=YOUR-WEB-CLIENT-ID.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=YOUR-IOS-CLIENT-ID.apps.googleusercontent.com

# Run the UI on seed data with no backend/auth (Expo Go / web):
#   EXPO_PUBLIC_USE_MOCK=1
